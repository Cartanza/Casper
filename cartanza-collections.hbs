{{#*inline "body"}}

<div class="cartanza-collection-grid" style="margin-top:30px;">
{{#foreach cartanzacollections}}
  <div class="cartanza-collection-card">
    <a href="/collections/{{slug}}">
      <div class="cartanza-collection-card-picture">
          <img class="cartanza-collection-card-picture-background" src="/content/images/products/{{image_src}}" width="183" loading="lazy" alt="{{image_alt}}">
      </div>
      <div class="cartanza-collection-card-info">
          <div>
            <h2 class="cartanza-collection-card-title" title="{{title}}" style="margin:0em;">
              {{title}}
            </h2>
          </div>
          <div class="cartanza-collection-card-description">
            {{{description}}}
          </div>
      </div>
    </a>
  </div>
{{/foreach}}
</div>

{{/inline}}
{{> default}}
