{{#*inline "body"}}
{{!-- The tag above means: insert everything in this file
into the {body} of the default.hbs template --}}

<div class="site-header-content outer{{#match @root.custom.header_style "Left aligned"}} left-aligned{{/match}}{{#unless @root.custom.show_publication_cover}}{{#match @root.custom.header_style "Hidden"}} no-content{{/match}}{{/unless}}">

    {{#if @root.custom.show_publication_cover}}
        {{#if @root.site.cover_image}}
            {{!-- This is a responsive image, it loads different sizes depending on device
            https://medium.freecodecamp.org/a-guide-to-responsive-images-with-ready-to-use-templates-c400bd65c433 --}}
            <img class="site-header-cover"
                srcset="{{img_url @root.site.cover_image size="s"}} 300w,
                        {{img_url @root.site.cover_image size="m"}} 600w,
                        {{img_url @root.site.cover_image size="l"}} 1000w,
                        {{img_url @root.site.cover_image size="xl"}} 2000w"
                sizes="100vw"
                src="{{img_url @root.site.cover_image size="xl"}}"
                alt="{{@root.site.title}}"
            />
        {{/if}}
    {{/if}}

    {{#match @root.custom.header_style "!=" "Hidden"}}
        <div class="site-header-inner inner">
            {{#match @root.custom.navigation_layout "Logo on cover"}}
                {{#if @root.site.logo}}
                    <img class="site-logo" src="{{@root.site.logo}}" alt="{{@root.site.title}}">
                {{else}}
                    <h1 class="site-title">{{@root.site.title}}</h1>
                {{/if}}
            {{/match}}
            {{#if @root.site.description}}
                <p class="site-description">{{@root.site.description}}</p>
            {{/if}}
        </div>
    {{/match}}

</div>

{{!-- The main content area --}}
<main id="site-main" class="site-main outer">
<div class="inner posts">

    <div class="post-feed">
        {{#foreach posts}}
            {{!-- The tag below includes the markup for each post - partials/post-card.hbs --}}
            {{> partials/post-card}}
        {{/foreach}}
    </div>

    {{pagination}}

</div>
</main>
{{/inline}}
{{> default}}